# ── MultiChain Dashboard — Frontend Environment Variables ────────────────────
#
# Copy this file to .env and fill in the values before running the frontend.
# Never commit your real .env file to git — it is already in .gitignore.
#
# Usage:
#   cp .env.example .env
#   # Then open .env and replace the placeholder values below.
#
# ─────────────────────────────────────────────────────────────────────────────

# 1. Backend API URL
#    The base URL of the FastAPI backend. Defaults to localhost:8000 in development.
#    In production, set this to your deployed backend URL:
#      REACT_APP_API_URL=https://api.yourdomain.com
REACT_APP_API_URL=http://localhost:8000

# 2. Sovereign API Key
#    Must match the SOVEREIGN_API_KEY set in backend/.env
#    Every frontend request includes this as: X-API-Key: <value>
#    Leave blank in development if SOVEREIGN_API_KEY is also blank (auth disabled).
REACT_APP_API_KEY=

# 3. WalletConnect Project ID
#    Required for RainbowKit wallet modal to work (MetaMask, WalletConnect QR, etc.)
#    Get a FREE project ID (takes 30 seconds) at: https://cloud.walletconnect.com
#    1. Sign in → New Project → copy the Project ID
#    2. Paste it here:
REACT_APP_WALLETCONNECT_PROJECT_ID=

# 4. Wallet Verification Sign Message
#    Must match SIGN_MESSAGE in backend/.env exactly.
#    This string is shown to the user in their wallet when they connect,
#    and the backend uses the same string to recover the signer address.
#    Changing this invalidates all previously issued signatures.
REACT_APP_SIGN_MESSAGE=Sign this to verify wallet ownership on SOVEREIGN Dashboard

# 5. Bridge Simulation Mode
#    When set to "true", useBridge() will skip the real LayerZero contract call
#    and instead return a fake tx hash (prefixed "0xSIM_") after a 1-second delay.
#    This lets you develop and test the full bridge UI without a funded wallet
#    or a live RPC connection.
#
#    Also triggered per-request when the /bridge/quote response contains
#    { "simulated": true } (i.e., when the backend is also in sim mode).
#
#    Set to "false" (or remove) in production to use real transactions.
REACT_APP_BRIDGE_SIMULATE=true

# ── MultiChain Dashboard — Environment Variables ──────────────────────────
#
# Copy this file to .env and fill in your API keys before running the backend.
# Never commit your real .env file to git — add .env to .gitignore.
#
# Usage:
#   cp .env.example .env
#   # Then open .env and replace the placeholder values below.
#
# ─────────────────────────────────────────────────────────────────────────────

# 1. Moralis API Key — https://admin.moralis.io/
#    Used for: Ethereum, Polygon, BSC token balances, NFTs, and transactions
MORALIS_API_KEY=

# 2. Helius API Key — https://dev.helius.xyz/
#    Used for: Solana SPL token balances
HELIUS_API_KEY=

# 3. CoinGecko API Key — https://www.coingecko.com/en/api
#    Optional — leave blank to use the free public tier (rate limited).
#    Set this to a Pro key to use pro-api.coingecko.com for higher limits.
COINGECKO_API_KEY=

# 4. OpenAI API Key — https://platform.openai.com/api-keys
#    Used for: AI Advisor (JULIUS-inspired AutoGen agent)
#    Leave blank to use rule-based fallback instead
OPENAI_API_KEY=

# 5. AI Model (optional, defaults to gpt-4o-mini)
ADVISOR_MODEL=gpt-4o-mini

# 5b. AI Model temperature (optional, defaults to 0.2)
#     Lower = more deterministic. Higher = more creative.
#     Valid range: 0.0 – 2.0
ADVISOR_TEMPERATURE=0.2

# 6. Allowed CORS Origins — https://developer.mozilla.org/en-US/docs/Web/HTTP/CORS
#    Comma-separated list of frontend origins permitted to call the API.
#    Leave blank in development — main.py defaults to localhost:3000 and localhost:5500.
#    In production, set this to your actual frontend URL(s):
#      ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=

# 7. Sovereign API Key — shared secret for X-API-Key header authentication
#    All API requests must include this header: X-API-Key: <value>
#    Leave blank in development to disable enforcement.
#    Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SOVEREIGN_API_KEY=

# 8. PostgreSQL Database URL — SQLAlchemy async connection string
#    Driver: asyncpg (required for SQLAlchemy async engine)
#    Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
#
#    Local dev example (default if left blank):
#      DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sovereign
#
#    After setting this, initialise the schema:
#      cd backend && alembic upgrade head
#      # OR for dev only: the app calls init_db() on startup
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sovereign

# 9. Wallet Verification Message — challenge string for EIP-191 personal_sign
#    The frontend signs this exact string with MetaMask / RainbowKit signMessage().
#    The backend recovers the signer and checks it matches the claimed address.
#    Change this string to invalidate all previously issued signatures.
SIGN_MESSAGE=Sign this to verify wallet ownership on SOVEREIGN Dashboard

# 10. Chain Health Monitor — RPC URL Overrides
#     chain_monitor.py uses public fallbacks by default, but they can be
#     rate-limited. Set private Alchemy / Infura / QuickNode endpoints here
#     to guarantee reliable health data.
#
#     Alchemy URL format:
#       https://<network>.g.alchemy.com/v2/<your-alchemy-api-key>
#
#     Leave any entry blank to keep using the public fallback.
ETHEREUM_RPC_URL=
POLYGON_RPC_URL=
ARBITRUM_RPC_URL=
BSC_RPC_URL=
SOLANA_RPC_URL=
